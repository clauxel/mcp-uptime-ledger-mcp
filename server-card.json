{
  "name": "mcpuptimeledger",
  "title": "MCP Uptime Ledger",
  "description": "Run uptime, latency, schema, and auth checks for MCP servers, then issue SLA receipts and status reports.",
  "version": "1.0.0",
  "websiteUrl": "https://mcpuptimeledger.clauxel.com/",
  "documentationUrl": "https://mcpuptimeledger.clauxel.com/mcp/",
  "endpointUrl": "https://mcpuptimeledger.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://mcpuptimeledger.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://mcpuptimeledger.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://mcpuptimeledger.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "starter",
        "name": "Starter",
        "monthlyUsd": 49
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 149
      },
      {
        "id": "platform",
        "name": "Platform",
        "monthlyUsd": 399
      }
    ]
  },
